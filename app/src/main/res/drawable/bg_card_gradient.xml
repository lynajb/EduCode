<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!--
       angle="90" means Bottom to Top
       startColor = Bottom (Darker)
       endColor = Top (Lighter)
    -->
    <gradient
        android:angle="90"
        android:startColor="#FFA73B"
        android:endColor="#E24400"
        android:type="linear" />

    <!-- Must match your CardView corner radius -->
    <corners android:radius="24dp" />
</shape>