<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
>
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/i8"
        android:scaleType="centerCrop"
/>
    <!-- 1. IMAGE (Now at the top) -->
    <ImageView
        android:id="@+id/imgHeaderDecoration"
        android:layout_width="150dp"
        android:layout_height="150dp"
        android:layout_alignParentTop="true"
        android:layout_centerHorizontal="true"
        android:src="@drawable/i6" />

    <!-- 2. Page Title (Now below the image) -->
    <TextView
        android:id="@+id/tvPageTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/imgHeaderDecoration"
        android:layout_centerHorizontal="true"
        android:text="RÉSULTATS"
        android:textColor="#FFD702"
        android:textSize="28sp"
        android:textStyle="bold"
        android:letterSpacing="0.1"/>

    <!-- 3. The Main Card (Positioned below the title) -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardResult"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/tvPageTitle"
        android:layout_marginTop="20dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="15dp"
        app:cardBackgroundColor="@android:color/transparent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card_gradient"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="32dp">

            <!-- Comment Text -->
            <TextView
                android:id="@+id/tvResultComment"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:gravity="center"
                android:text="Excellent travail !"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold" />

            <!-- Yellow Circle for Score -->
            <FrameLayout
                android:layout_width="140dp"
                android:layout_height="140dp"
                android:layout_marginBottom="24dp"
                android:background="@drawable/circle_yellow_background">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvFinalScore"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:includeFontPadding="false"
                        android:text="8"
                        android:textColor="#4E1B1B"
                        android:textSize="56sp"
                        android:textStyle="bold" />

                    <View
                        android:layout_width="40dp"
                        android:layout_height="2dp"
                        android:layout_marginTop="2dp"
                        android:layout_marginBottom="2dp"
                        android:background="#2D1B4E" />

                    <TextView
                        android:id="@+id/tvTotalQuestions"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="sur 10"
                        android:textColor="#4E1B1B"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </FrameLayout>

            <!-- Correct Answers Label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:letterSpacing="0.05"
                android:text="Réponses correctes"
                android:textAllCaps="true"
                android:textColor="#4F1D1D"
                android:textSize="14sp" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- 4. Buttons at the Bottom -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="20dp"
        android:orientation="vertical">

        <!-- Replay Button -->
        <Button
            android:id="@+id/btnReplay"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="  Rejouer"
            android:backgroundTint="#EC6716"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            app:icon="@android:drawable/ic_menu_rotate"
            app:iconTint="#FFFFFF"
            app:iconGravity="textStart"
            app:cornerRadius="30dp"
            android:layout_marginBottom="12dp"/>

        <!-- Home Button -->
        <Button
            android:id="@+id/btnHome"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="Retour à l'accueil"
            android:backgroundTint="#FFBD02"
            android:textColor="#4F1D1D"
            android:textSize="14sp"
            app:strokeColor="#640000"
            app:strokeWidth="1dp"
            app:cornerRadius="30dp"/>

    </LinearLayout>

</RelativeLayout>